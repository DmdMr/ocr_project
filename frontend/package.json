{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "frontend": "npm run dev -- --host 0.0.0.0",
    "backend": "bash -c 'source venv/bin/activate && uvicorn backend.app.main:app --reload --host 0.0.0.0 --port 8000'",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.10.1",
    "concurrently": "^9.2.1",
    "svelte": "^5.54.0",
    "svelte-check": "^4.3.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "svelte-spa-router": "^5.0.0"
  }
}
